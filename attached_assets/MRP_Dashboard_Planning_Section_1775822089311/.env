# PostgreSQL Connection (Used by Backend)
DATABASE_URL="postgresql://mrp:admin@localhost:5432/mrp_db"

# API Configuration (Used by Frontend)
VITE_API_URL="http://localhost:8000/api/v1"

# Sync Configuration
VITE_SYNC_INTERVAL_MS=300000
VITE_ENABLE_OFFLINE_MODE=true

# PostgreSQL Database Configuration
DB_HOST=mrpdb
DB_PORT=5432
DB_NAME=mrp
DB_USER=mrp
DB_PASSWORD=admin

# Backend API Server
API_PORT=5000
API_HOST=localhost

