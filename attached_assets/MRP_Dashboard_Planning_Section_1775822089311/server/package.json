{
  "name": "@mrp/server",
  "version": "1.0.0",
  "description": "MRP Dashboard Backend Server - PostgreSQL API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm --no-warnings=ExperimentalWarning index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "schema": "psql -U postgres -d mrp_dashboard -f schema.sql"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "ts-node": "^10.9.2"
  }
}
